PROJECT=todoapp
ENV=prod
DOMAIN=example.com
CONTAINER_PROVIDER=docker

# SSH target for `deno task deploy`. `homelab` must be in ~/.ssh/config.
SSH_TO_SERVER=homelab
# Destination directory on the remote. Deploy will rsync into this path.
PATH_ON_SERVER=~/apps/todoapp

# === Secrets — generate fresh values for production ===
# See README → "Generate secrets" for one-liners.

AUTH_PEPPER=YOUR_AUTH_PEPPER_HERE
AUTH_COOKIE_SECRET=YOUR_AUTH_COOKIE_SECRET_HERE
ENCRYPTION_SECRET=YOUR_ENCRYPTION_SECRET_HERE

# Allowed CORS origin. Set to your frontend's public URL.
CORS_ORIGIN=https://todos.${DOMAIN}
